# Supabase Postgres (preferred: single URL)
# Replace YOUR_DB_PASSWORD with your Supabase database password.
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.zaeklpatmznlkhgjqprl.supabase.co:5432/postgres?sslmode=require
# If direct host resolves IPv6-only on your machine, use Supabase pooler:
# DATABASE_URL=postgresql://postgres.zaeklpatmznlkhgjqprl:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Or configure Postgres fields individually:
PGHOST=db.zaeklpatmznlkhgjqprl.supabase.co
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=
DB_SSLMODE=require

# Redis connection (choose one approach)

# 1) Full URL form (preferred for managed Redis providers):
# REDIS_URL=redis://default:your_password@your-host:your-port/0
# REDIS_URL=rediss://default:your_password@your-host:your-port/0

# 2) Host/port/user/password form (local docker compose default):
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false

# Flask cache behavior
CACHE_TTL_SECONDS=900
AUTH_TOKEN_TTL_SECONDS=43200

# Gemini AI
GEMINI_API_KEY=

# AI worker knobs
SCAN_FETCH_LIMIT=1000
POLL_INTERVAL_SECONDS=300
MAX_SPEED_KMH=900
DBSCAN_EPS_KM=15
DBSCAN_MIN_SAMPLES=4
ALERT_DEDUP_MINUTES=30
